# ChurnShield Workspace Environment Variables

# Frontend Environment Variables
# The URL of the deployed FastAPI backend API.
# Set this in Vercel to point the frontend to the deployed backend.
VITE_API_URL=https://your-churnshield-backend.onrender.com

# Backend Environment Variables
# The FastAPI backend currently runs completely locally without external database or API dependencies,
# so no backend environment variables are required.
# However, if you decide to customize the port or host in production, you can specify them here:
PORT=8000
HOST=0.0.0.0
