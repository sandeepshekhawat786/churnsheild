# ChurnShield Frontend Environment Variables

# The URL of the deployed FastAPI backend API. 
# In local development, Vite proxies requests to http://127.0.0.1:8000.
# For production (e.g., Vercel), set this to your hosted backend URL (e.g. Render, Railway, or AWS).
VITE_API_URL=https://your-churnshield-backend.onrender.com
